<!DOCTYPE html>
<html lang="kk">
<head>
  <meta charset="UTF-8">
  <title>Баға пакеттері</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="header">
    <div class="container">
      <h1 class="logo">Kids Play</h1>
      <nav><a href="/">Басты бет</a></nav>
    </div>
  </header>
  <main class="container">
    <h2 style="text-align:center; margin: 30px 0;">Баға пакеттері</h2>
    <div class="prices-grid">
      <div class="price-card">
        <h3>Базалық</h3>
        <p class="amount">2 500 ₸</p>
        <ul>
          <li>2 сағат ойын уақыты</li>
          <li>3 аттракционға кіру</li>
          <li>Сусын сыйлық</li>
        </ul>
        <a href="/booking" class="btn btn-secondary">Таңдау</a>
      </div>
      <div class="price-card featured">
        <h3>Стандарт ⭐</h3>
        <p class="amount">4 500 ₸</p>
        <ul>
          <li>4 сағат ойын уақыты</li>
          <li>Барлық аттракциондар</li>
          <li>Тамақ + сусын</li>
          <li>Фото сессия</li>
        </ul>
        <a href="/booking" class="btn btn-primary">Таңдау</a>
      </div>
      <div class="price-card">
        <h3>Премиум</h3>
        <p class="amount">7 500 ₸</p>
        <ul>
          <li>Бүкіл күн ойын</li>
          <li>VIP аймақ</li>
          <li>Тамақ + сусын + торт</li>
          <li>Жеке аниматор</li>
        </ul>
        <a href="/booking" class="btn btn-secondary">Таңдау</a>
      </div>
    </div>
  </main>
  <script src="/js/main.js"></script>
</body>
</html>
