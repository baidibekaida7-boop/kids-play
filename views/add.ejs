<!DOCTYPE html>
<html lang="kk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="header">
    <div class="container">
      <h1 class="logo">Kids Play</h1>
      <nav>
        <a href="/">Басты бет</a>
        <a href="/dashboard">Панель</a>
        <a href="/auth/logout">Шығу</a>
      </nav>
    </div>
  </header>

  <main class="container">
    <h2>Жаңа аттракцион қосу</h2>

    <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
      <div class="error-list">
        <% errors.forEach(err => { %>
          <p class="error"><%= err.msg %></p>
        <% }) %>
      </div>
    <% } %>

    <form action="/add" method="POST" class="form">
      <div class="form-group">
        <label for="name">Атауы</label>
        <input type="text" id="name" name="name" placeholder="Аттракцион атауы" required>
      </div>

      <div class="form-group">
        <label for="description">Сипаттама</label>
        <textarea id="description" name="description" rows="4" placeholder="Қысқаша сипаттама" required></textarea>
      </div>

      <div class="form-group">
        <label for="category">Категория</label>
        <select id="category" name="category">
          <option value="батуттар">Батуттар</option>
          <option value="лабиринт">Лабиринт</option>
          <option value="каруссель">Каруссель</option>
          <option value="аквапарк">Аквапарк</option>
          <option value="басқа">Басқа</option>
        </select>
      </div>

      <div class="form-group">
        <label for="minAge">Минималды жас</label>
        <input type="number" id="minAge" name="minAge" value="3" min="1" max="18">
      </div>

      <div class="form-group">
        <label for="maxAge">Максималды жас</label>
        <input type="number" id="maxAge" name="maxAge" value="14" min="1" max="18">
      </div>

      <div class="form-group">
        <label for="price">Баға (₸)</label>
        <input type="number" id="price" name="price" placeholder="1500" required min="0">
      </div>

      <button type="submit" class="btn btn-primary">Қосу</button>
      <a href="/dashboard" class="btn btn-secondary">Бас тарту</a>
    </form>
  </main>

  <script src="/js/main.js"></script>
</body>
</html>
